{
  "name": "@backendkit-labs/auto-learning",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "author": {
    "name": "BackendKit Labs",
    "email": "hello@backendkitlabs.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Self-tuning backend intelligence — learns from usage patterns, detects anomalies, and auto-adjusts resilience config (timeouts, retries, circuit breaker, bulkhead)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "auto-learning",
    "anomaly-detection",
    "self-tuning",
    "adaptive",
    "circuit-breaker",
    "bulkhead",
    "backend",
    "nestjs",
    "typescript"
  ],
  "homepage": "https://backendkitlabs.dev/docs/auto-learning/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BackendKit-labs/backendkit-monorepo.git",
    "directory": "packages/auto-learning"
  },
  "bugs": {
    "url": "https://github.com/BackendKit-labs/backendkit-monorepo/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@backendkit-labs/observability": "*",
    "@backendkit-labs/result": "*",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "@backendkit-labs/circuit-breaker": "*",
    "@backendkit-labs/bulkhead": "*",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@backendkit-labs/circuit-breaker": {
      "optional": true
    },
    "@backendkit-labs/bulkhead": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0"
  }
}
