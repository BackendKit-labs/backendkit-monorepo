{
  "name": "@backendkit-labs/circuit-breaker",
  "version": "0.1.1",
  "description": "Circuit Breaker pattern for Node.js â€” fail-fast with business vs infrastructure error classification, optional NestJS integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "keywords": [
    "circuit-breaker",
    "resilience",
    "fault-tolerance",
    "fail-fast",
    "nestjs",
    "node",
    "backend"
  ],
  "author": "Mairon JosÃ© Cuello MartÃ­nez <[backendkit.dev@gmail.com - mmairon@gmail.com]>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/backendkit-dev/backendkit-monorepo/tree/master/packages/circuit-breaker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backendkit-dev/backendkit-monorepo.git",
    "directory": "packages/circuit-breaker"
  },
  "bugs": {
    "url": "https://github.com/backendkit-dev/backendkit-monorepo/issues"
  },
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "rxjs": { "optional": true }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0"
  }
}

