{
  "name": "@backendkit-labs/request-scanner",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "author": {
    "name": "BackendKit Labs",
    "email": "hello@backendkitlabs.dev"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Pattern-based request scanner for Node.js - SQLi, XSS, Path Traversal, Command Injection, NoSQL Injection, SSRF detection with optional NestJS integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "keywords": [
    "scanner",
    "security",
    "sqli",
    "xss",
    "path-traversal",
    "injection",
    "nosql",
    "ssrf",
    "nestjs",
    "middleware",
    "node"
  ],
  "homepage": "https://backendkitlabs.dev/docs/request-scanner/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BackendKit-labs/backendkit-monorepo.git",
    "directory": "packages/request-scanner"
  },
  "bugs": {
    "url": "https://github.com/BackendKit-labs/backendkit-monorepo/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "express": ">=4.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0"
  }
}
