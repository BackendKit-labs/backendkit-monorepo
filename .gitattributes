# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Explicitly declare text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Declare binary files (never touch line endings)
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
