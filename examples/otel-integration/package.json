    "rxjs": "^7.8.0",
    "@backendkit-labs/circuit-breaker": "0.3.0",
    "@backendkit-labs/bulkhead": "0.2.0",
    "@backendkit-labs/observability": "0.2.1",
    "@backendkit-labs/auto-learning": "0.3.0",
    "@backendkit-labs/result": "0.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
