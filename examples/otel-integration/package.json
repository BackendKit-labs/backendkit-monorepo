{
  "name": "otel-integration",
  "version": "1.0.0",
  "private": true,
  "description": "BackendKit Labs — OTel integration demo: traces to Jaeger, metrics to Grafana",
  "scripts": {
    "build":       "nest build",
    "start":       "node --require ./dist/instrumentation.js dist/main",
